# API Key de Gemini (Google GenAI SDK)
GEMINI_API_KEY=AIzaSy...

# Configuración de la Caché Semántica
# Backend: 'qdrant' (por defecto, local) o 'redis'
SEMANTIC_CACHE_BACKEND=qdrant

# Umbral de similitud (similarity threshold) para cache hit
SEMANTIC_CACHE_THRESHOLD=0.95

# Tiempo de vida de la caché en días (TTL)
SEMANTIC_CACHE_TTL_DAYS=7.0

# URL de Redis (solo necesaria si backend=redis)
REDIS_URL=redis://localhost:6379
